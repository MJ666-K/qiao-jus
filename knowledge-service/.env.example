# ===== App =====
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
# JWT: change in production! run `openssl rand -hex 32`
JWT_SECRET_KEY=change-me-to-a-random-64-char-hex-string
JWT_ALGORITHM=HS256
JWT_ACCESS_TTL_MINUTES=60
JWT_REFRESH_TTL_DAYS=7

# ===== Postgres =====
# dev: localhost（venv 跑在宿主机）；prod: 由 deploy/docker-compose.yml environment 覆盖为 postgres
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=fengqiao
POSTGRES_PASSWORD=fengqiao123
POSTGRES_DB=fengqiao
DATABASE_URL=postgresql+asyncpg://fengqiao:fengqiao123@localhost:5432/fengqiao

# ===== Qdrant =====
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=knowledge
QDRANT_VECTOR_SIZE=1024

# ===== Neo4j =====
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=fengqiao123

# ===== Redis / Celery =====
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ===== LLM (OpenAI-compatible; works with DashScope/ZhipuAI/OpenAI/vLLM/etc.) =====
# DashScope (Qwen) example:
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your_api_key_here
LLM_MODEL_ID=qwen-plus
LLM_MAX_TOKENS=8000

# Embedding model id at the same endpoint (DashScope: text-embedding-v3 / v4)
EMBEDDING_MODEL_ID=text-embedding-v3
EMBEDDING_DIM=1024

# ===== Chunking =====
CHUNK_PARENT_TOKENS=1200
CHUNK_CHILD_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

# ===== Retrieve =====
SEARCH_TOP_K=10
RRF_K=60
RERANK_TOP_K=20

# ===== Aliyun OSS (required for file uploads; no local-disk fallback) =====
#OSS_ACCESS_KEY_ID=your_oss_access_key_id
#OSS_ACCESS_KEY_SECRET=your_oss_access_key_secret
#OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
#OSS_BUCKET_NAME=your-bucket
#OSS_PREFIX=uploads/
