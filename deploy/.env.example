# ===== App =====
APP_ENV=production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_LOG_LEVEL=INFO
JWT_SECRET_KEY=
JWT_ALGORITHM=
JWT_ACCESS_TTL_MINUTES=
JWT_REFRESH_TTL_DAYS=7

# ===== Postgres（Docker 服务名 postgres，容器内端口 5432）=====
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DB=
DATABASE_URL=postgresql+asyncpg://:@postgres:5432/

# ===== Qdrant（Docker 服务名 qdrant，HTTP 6333）=====
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=knowledge
QDRANT_VECTOR_SIZE=1024

# ===== Neo4j（Docker 服务名 neo4j，Bolt 7687）=====
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=
NEO4J_PASSWORD=

# ===== Redis / Celery（Docker 服务名 redis，6379）=====
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ===== LLM (OpenAI-compatible; DashScope / Qwen) =====
LLM_API_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=sk-
LLM_MODEL_ID=deepseek-v4-flash
LLM_MAX_TOKENS=8000

# ===== Embedding =====
EMBEDDING_MODEL_ID=text-embedding-v3
EMBEDDING_DIM=1024

# ===== Chunking =====
CHUNK_PARENT_TOKENS=1200
CHUNK_CHILD_TOKENS=300
CHUNK_OVERLAP_TOKENS=50

# ===== Retrieve =====
SEARCH_TOP_K=10
RRF_K=60
RERANK_TOP_K=20
BM25_K1=1.5
BM25_B=0.75
DENSE_TOP_K_MULTIPLIER=3

# ===== Rerank =====
RERANK_MODEL_ID=qwen3-rerank
RERANK_API_URL=https://dashscope.aliyuncs.com/compatible-api/v1/reranks
RERANK_INSTRUCT=Given a web search query, retrieve relevant passages that answer the query.

# ===== Aliyun OSS (required for file uploads; objects stored at OSS, no local disk) =====
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=
OSS_ENDPOINT=https://oss-cn-shanghai.aliyuncs.com
OSS_BUCKET_NAME=kim-1001
OSS_PREFIX=uploads/
